# =====================================
# WinMonitor Web V2 - Environment Setup
# =====================================

# Gemini AI key (if your app/features still use Gemini integration)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ----------------
# API & Auth
# ----------------
# Backend base URL.
# You can set either:
# - http://localhost:3002
# - http://localhost:3002/api
# The app will normalize this automatically for REST (/api) and Socket.IO.
VITE_API_URL="http://localhost:3002"

# Optional fallback API key.
# Preferred runtime flow is saving key into localStorage (winmonitor_api_key).
VITE_API_KEY=""

# Axios timeout (milliseconds)
VITE_API_TIMEOUT="30000"

# ----------------
# Socket.IO
# ----------------
# Number of reconnect attempts when socket disconnects
VITE_SOCKET_RECONNECT_ATTEMPTS="5"

# Delay between reconnect attempts (milliseconds)
VITE_SOCKET_RECONNECT_DELAY="2000"

# ----------------
# File Manager
# ----------------
# Default start path for Files page
VITE_FILE_DEFAULT_PATH="C:/Innotech"

# ----------------
# Polling Intervals (ms)
# ----------------
VITE_POLL_SYSTEM_OVERVIEW="3000"
VITE_POLL_CPU="2000"
VITE_POLL_MEMORY="2000"
VITE_POLL_DISK="10000"
VITE_POLL_NETWORK="3000"
VITE_POLL_PROCESSES="5000"
VITE_POLL_PM2="5000"
VITE_POLL_JOBS="15000"
VITE_POLL_ALERTS="15000"

# ----------------
# App Settings
# ----------------
# Locale for date/number formatting
VITE_LOCALE="vi-VN"

# Max points used by rolling history chart hooks
VITE_HISTORY_MAX_POINTS="60"
